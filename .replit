modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

# Cache-Control headers for static assets — hashed JS/CSS are immutable,
# images/cacheable resources get long TTL, HTML stays fresh for SPA routing.
[[deployment.responseHeaders]]
path = "/assets/*"
name = "Cache-Control"
value = "public, max-age=31536000, immutable"

[[deployment.responseHeaders]]
path = "/*.js"
name = "Cache-Control"
value = "public, max-age=31536000, immutable"

[[deployment.responseHeaders]]
path = "/*.css"
name = "Cache-Control"
value = "public, max-age=31536000, immutable"

[[deployment.responseHeaders]]
path = "/*.jpg"
name = "Cache-Control"
value = "public, max-age=86400"

[[deployment.responseHeaders]]
path = "/*.jpeg"
name = "Cache-Control"
value = "public, max-age=86400"

[[deployment.responseHeaders]]
path = "/*.png"
name = "Cache-Control"
value = "public, max-age=86400"

[[deployment.responseHeaders]]
path = "/*.webp"
name = "Cache-Control"
value = "public, max-age=86400"

[[deployment.responseHeaders]]
path = "/*.svg"
name = "Cache-Control"
value = "public, max-age=86400"

[[deployment.responseHeaders]]
path = "/*.ico"
name = "Cache-Control"
value = "public, max-age=604800"

[[deployment.responseHeaders]]
path = "/llms.txt"
name = "Cache-Control"
value = "public, max-age=86400"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lint"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "format"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "forsa-design-test"

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "lint"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run lint"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "format"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run format:check"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "forsa-design-test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/forsa-design run test"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["google-mail:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080

[[ports]]
localPort = 8081

[[ports]]
localPort = 8082

[[ports]]
localPort = 20815

